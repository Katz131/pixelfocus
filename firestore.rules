rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Player profiles ──────────────────────────────────────────────
    // Public read (profile pages, friend lookups).
    // Write limited to 50 top-level fields and 500 KB to prevent abuse.
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if request.resource.data.keys().size() <= 50
                   && request.resource.size < 500 * 1024;

      // Shared config (mirror-mode sync between browsers)
      match /shared/{docId} {
        allow read: if true;
        allow write: if request.resource.data.keys().size() <= 50
                     && request.resource.size < 500 * 1024;
      }

      // Social data (friends list, challenge state, permissions)
      match /social/{docId} {
        allow read: if true;
        allow write: if request.resource.data.keys().size() <= 30
                     && request.resource.size < 100 * 1024;
      }

      // Inbox (friend requests, challenge invites, morse messages, tasks)
      match /inbox/{msgId} {
        allow read: if true;
        allow create: if request.resource.data.keys().size() <= 20
                      && request.resource.size < 10 * 1024;
        allow delete: if true;
        // No update — messages are write-once, then deleted after processing
      }
    }
  }
}
