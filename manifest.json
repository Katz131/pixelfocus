{
  "manifest_version": 3,
  "name": "PixelFocus",
  "version": "3.19.10",
  "description": "Gamified Pomodoro todo list - earn pixel blocks by staying focused and build pixel art!",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
